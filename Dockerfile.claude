# The GUID tag ensures this resolves to the locally-built dev image and never
# accidentally pulls a stranger's image from Docker Hub.
FROM hodoku-dev:693f55f2-e0e7-4624-8f8f-5f0bf01e51dd

# Node.js LTS via NodeSource — Debian's bundled version is too old for Claude Code.
# git is required by Claude Code for repository operations.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl git \
    && curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Git read-only wrapper — blocks write operations so Claude can't commit or push.
# Placed at /usr/local/bin/git (ahead of the real git in PATH).
RUN real_git=$(which git) && \
    cat > /usr/local/bin/git <<EOF
#!/bin/bash
case "\$1" in
  commit|push|reset|merge|rebase|clean|tag)
    echo "git \$1 is disabled (read-only container)" >&2; exit 1 ;;
  checkout|switch)
    # allow read-only forms (e.g. checkout <file> is fine; block branch switching)
    if echo "\$@" | grep -qE '^\s*(checkout|switch)\s+-'; then
      echo "git \$1 is disabled (read-only container)" >&2; exit 1
    fi
    exec $real_git "\$@" ;;
  branch)
    # allow listing (git branch, git branch -a) but block create/delete/rename
    if echo "\$@" | grep -qE '(-d|-D|-m|-M|-c|-C)'; then
      echo "git branch write ops are disabled (read-only container)" >&2; exit 1
    fi
    exec $real_git "\$@" ;;
  *)
    exec $real_git "\$@" ;;
esac
EOF
RUN chmod +x /usr/local/bin/git

# Pass your API key at runtime:
#   docker run -it --rm -v "$(pwd)":/workspace -e ANTHROPIC_API_KEY=... hodoku-claude:693f55f2-e0e7-4624-8f8f-5f0bf01e51dd
#
# Build order (base image must exist first):
#   docker build -f Dockerfile.dev   -t hodoku-dev:693f55f2-e0e7-4624-8f8f-5f0bf01e51dd .
#   docker build -f Dockerfile.claude -t hodoku-claude:693f55f2-e0e7-4624-8f8f-5f0bf01e51dd .

ENTRYPOINT ["claude"]
